if (var "toSell" == 0 0) {
    chat "&cYou have no items to sell!"
    sound "Anvil Land" 0.7 1.0 "invokers_location"
    var "toSell" unset
    exit
}

var "money" inc %var.player/toSell 0%
sound "Orb Pickup" 0.7 1.0 "invokers_location"
