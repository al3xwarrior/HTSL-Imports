if (var isbreaking == 1 0, !hasItem "minecraft:wooden_pickaxe" "Item Type" "Hand" "Any Amount") {
    removeItem "minecraft:wooden_pickaxe"
    giveItem "minecraft:wooden_pickaxe" true "Hand" true
}

goto event "Player Toggle Sneak"

if (var isbreaking == 1 0) {
    var isbreaking set 0 false
    function Adventure false
    applyLayout "Main Menu"
}



