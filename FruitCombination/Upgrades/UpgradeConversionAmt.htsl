
if (var money < %var.player/conversionamtcost 100%) {
    sound "Anvil Land" 0.7 1.0 "invokers_location"
    chat "&cYou do not have enough money to purchase this!"
    exit
}

var money dec %var.player/conversionamtcost 0%
var conversionamt inc 1
var conversionamtcost mult 2

sound "Level Up" 0.7 1.0 "invokers_location"
title "&a&oUpgrade Purchased!" "&7Your conversion amount is now &a%var.player/conversionamt 0%&7!" 0 1 1
