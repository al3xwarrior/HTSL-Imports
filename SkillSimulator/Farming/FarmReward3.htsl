// Farm3 potato reward; unlocks at shared level 22

var farmamount set 1
var xpgain set 46
var tokengain set 4
function "FarmBase" false

loop 32 index {
    if (var farmamount > {index}) {
        giveItem "../Items/potato" true "First Slot" false
    }
}

sound "Item Pickup" 0.7 1.3 "invokers_location"
title "&a&lFARM" "&7+%var.player/farmamount 1% Potato" 0 1 1

