loop 128 index {
    if (hasItem "../Items/enchanted_sugar_cane64" metadata Anywhere anyAmount) {
        removeItem "../Items/enchanted_sugar_cane64"
        giveItem "../Items/sugar_cane_block" true "First Slot" false
        var condensecount inc 1
    }
}
loop 128 index {
    if (hasItem "../Items/enchanted_pumpkin64" metadata Anywhere anyAmount) {
        removeItem "../Items/enchanted_pumpkin64"
        giveItem "../Items/pumpkin_block" true "First Slot" false
