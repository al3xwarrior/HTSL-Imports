    if (hasItem "../Items/sugar_cane64" metadata Anywhere anyAmount) {
        removeItem "../Items/sugar_cane64"
        giveItem "../Items/enchanted_sugar_cane" true "First Slot" false
        var condensecount inc 1
    }
}
loop 128 index {
    if (hasItem "../Items/pumpkin64" metadata Anywhere anyAmount) {
        removeItem "../Items/pumpkin64"
        giveItem "../Items/enchanted_pumpkin" true "First Slot" false
        var condensecount inc 1
    }
}

loop 128 index {
    if (hasItem "../Items/enchanted_wheat64" metadata Anywhere anyAmount) {
        removeItem "../Items/enchanted_wheat64"
        giveItem "../Items/wheat_block" true "First Slot" false
        var condensecount inc 1
    }
}
