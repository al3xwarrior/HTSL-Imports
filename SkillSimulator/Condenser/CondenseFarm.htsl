// farming item condense rules; 64 raw -> enchanted, 64 enchanted -> block

loop 128 index {
    if (hasItem "../Items/wheat64" metadata Anywhere anyAmount) {
        removeItem "../Items/wheat64"
        giveItem "../Items/enchanted_wheat" true "First Slot" false
        var condensecount inc 1
    }
}
loop 128 index {
    if (hasItem "../Items/carrot64" metadata Anywhere anyAmount) {
        removeItem "../Items/carrot64"
        giveItem "../Items/enchanted_carrot" true "First Slot" false
        var condensecount inc 1
    }
}
loop 128 index {
    if (hasItem "../Items/potato64" metadata Anywhere anyAmount) {
        removeItem "../Items/potato64"
        giveItem "../Items/enchanted_potato" true "First Slot" false
        var condensecount inc 1
    }
}
