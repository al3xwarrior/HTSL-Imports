// upgrades mining Power; increases ore quantity

if (var minepower >= 50 0) {
    chat "&cPower is maxed."
    exit
}
if (var tokens < %var.player/minepowercost 12%) {
    chat "&cNot enough tokens."
    sound "Anvil Land" 0.7 1 "invokers_location"
    exit
}
var tokens dec %var.player/minepowercost 12%
var minepower inc 1
var minepowercost mult 125
var minepowercost div 100
sound "Level Up" 0.7 1.2 "invokers_location"
function "OpenMiningEnchants" false

