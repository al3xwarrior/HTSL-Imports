// money passive; improves AFK region token, xp, and crate drip without beating active play

if (var money < %var.player/afkworkercost 1500%) {
    chat "&cNot enough money."
    sound "Anvil Land" 0.7 1 "invokers_location"
    exit
}
var money dec %var.player/afkworkercost 1500%
var afkworker inc 1
var afkworkercost mult 185
var afkworkercost div 100
sound "Level Up" 0.7 1.2 "invokers_location"
function "OpenPassives" false

